{
    "title": "Beyond the Night",
    "no_wrap": true,
    "text_block_list": [
        {
            "name": "Manhattan Cafe",
            "text": "It happened again... I couldn't reach the other\nside..."
        },
        {
            "name": "Manhattan Cafe",
            "text": "...My body feels sluggish."
        },
        {
            "name": "Manhattan Cafe",
            "text": "The moon looks... huge somehow?"
        },
        {
            "name": "Manhattan Cafe",
            "text": "Huh?"
        },
        {
            "name": "Manhattan Cafe",
            "text": "It's getting... bigger and bigger..."
        },
        {
            "name": "Manhattan Cafe",
            "text": "Ah... I'm here again..."
        },
        {
            "name": "Manhattan Cafe",
            "text": "Oh? ...Now's my chance?"
        },
        {
            "name": "Manhattan Cafe",
            "text": "It's now or never? Okay, I understand..."
        },
        {
            "name": "Manhattan Cafe",
            "text": "I'll sprint right down the middle, in one go!"
        },
        {
            "name": "Manhattan Cafe",
            "text": "Deep breaths..."
        },
        {
            "name": "Manhattan Cafe",
            "text": "Go!"
        },
        {
            "name": "Monologue",
            "text": "Running like the wind, Manhattan Cafe speeds\nacross the rickety rope bridge! And then..."
        },
        {
            "name": "Manhattan Cafe",
            "text": "Thanks for waiting!"
        },
        {
            "name": "Manhattan Cafe",
            "text": "<i>Huff... Huff...</i>"
        },
        {
            "name": "Manhattan Cafe",
            "text": "Huh? What the..."
        },
        {
            "name": "Manhattan Cafe",
            "text": "Just now, what did I... I feel like... it was\nsomething important..."
        },
        {
            "name": "Manhattan Cafe",
            "text": "...Oh."
        },
        {
            "name": "Manhattan Cafe",
            "text": "...It's beautiful."
        }
    ]
}